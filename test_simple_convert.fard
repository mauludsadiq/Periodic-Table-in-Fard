import("std/io") as io
import("std/rec") as rec
import("std/csv") as csv
import("std/list") as list

fn main() {
  let result = io.read_file("data/pubchem_periodic_table.csv") in
  let text = rec.get(result, "ok") in
  let rows = csv.parse(text) in
  let headers = list.head(rows) in
  let data_rows = list.tail(rows) in
  let first_row = list.head(data_rows) in
  
  // Simple manual conversion for first row
  let record = {
    AtomicNumber: list.head(first_row),
    Symbol: list.head(list.tail(first_row))
  } in
  let symbol = rec.get(record, "Symbol") in
  io.write_file("out/simple_test.txt", symbol)
}
main()
