import("std/io") as io
import("std/rec") as rec
import("std/csv") as csv
import("std/list") as list

fn main() {
  let result = io.read_file("data/pubchem_periodic_table.csv") in
  let text = rec.get(result, "ok") in
  let rows = csv.parse(text) in
  let headers = list.head(rows) in
  let data_rows = list.tail(rows) in
  let first_row = list.head(data_rows) in
  
  // Build record manually
  let record = rec.set({}, "AtomicNumber", list.head(first_row)) in
  let record2 = rec.set(record, "Symbol", list.head(list.tail(first_row))) in
  let symbol = rec.get(record2, "Symbol") in
  io.write_file("out/manual.txt", symbol)
}
main()
