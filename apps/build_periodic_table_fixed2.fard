import("std/io") as io
import("std/list") as list
import("std/str") as str
import("./packages/collapse-core/src/types") as ctypes

fn main() {
  let _ = io.make_dir("out") in
  let config = ctypes.build_config() in
  let manifest = ctypes.make_build_manifest(config, {total: 0, e_phase: 0, z_phase: 0, one_phase: 0}, ["Test"]) in
  let _ = io.write_file("out/test_manifest.json", "{}") in
  manifest
}

main()
